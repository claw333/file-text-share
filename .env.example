# Public hostname or a dedicated public IPv4 address. DNS A/AAAA records for a
# hostname must already point to this server. IP certificates are short-lived.
PUBLIC_HOST=share.example.com

# Optional Let's Encrypt account and expiry-notification email. Leave empty to
# register without email; adding a real address is recommended for recovery.
LETSENCRYPT_EMAIL=admin@example.com

# Set true only while testing certificate issuance against Let's Encrypt staging.
LETSENCRYPT_STAGING=false

# Use file-text-share-staging for staging certificate tests so its volumes are
# isolated from production. Keep file-text-share for the real deployment.
COMPOSE_PROJECT_NAME=file-text-share

# Optional local image label.
APP_IMAGE_TAG=local
